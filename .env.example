# Spec-Atlas configuration — copy to `.env` (gitignored) and fill in.
# Defaults are offline & zero-cost (both providers = fake). You only need real
# values to run against a live database or a real model.

# --- Databases (two separate logical DBs; see DATA-MODEL.md) ------------------
# Free options: Neon (managed Postgres, pgvector) or a local Postgres in Docker.
# pgvector must be enabled in the Analysis DB. Leave unset to boot without a DB.
ANALYSIS_DB_URL=postgresql+psycopg://user:password@host:5432/spec_atlas_analysis
SPEC_DB_URL=postgresql+psycopg://user:password@host:5432/spec_atlas_spec

# --- Providers ---------------------------------------------------------------
# LLM_PROVIDER:   fake | gemini | groq | ollama   (default: fake)
# EMBED_PROVIDER: fake | fastembed                (default: fake)
LLM_PROVIDER=fake
EMBED_PROVIDER=fake

# Model names (only used by the real providers).
LLM_MODEL=gemini-1.5-flash
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Embedding dimension — MUST match embeddings.vector(N) in the schema.
EMBED_DIM=384

# --- Provider credentials (never commit real keys; .env is gitignored) -------
# Only required when LLM_PROVIDER is the matching real provider.
GEMINI_API_KEY=

# Groq — get free keys at console.groq.com
# For rate-limit resilience, add keys from multiple free accounts (comma-separated).
# GROQ_API_KEYS is used for round-robin rotation and takes priority over GROQ_API_KEY.
GROQ_API_KEY=gsk_your_key_here
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral            # or: neural-chat, llama2

# If using Gemini
# GEMINI_API_KEY=AIza...

# --- CORS (production) -------------------------------------------------------
# Comma-separated list of allowed origins. Defaults to localhost dev ports.
# Set to your production domain(s) when deploying.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com
