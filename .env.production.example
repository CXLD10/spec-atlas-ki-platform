# Spec-Atlas Production Environment Template
# Copy to .env and fill in the production values.
# IMPORTANT: Do NOT commit .env to git (it's in .gitignore).

# --- Databases (REQUIRED for production) ------
# Use Neon.tech (free tier: 0.5GB storage, 20 concurrent connections)
# or managed PostgreSQL service (AWS RDS, Azure Database, etc.)
ANALYSIS_DB_URL=postgresql+psycopg://user:password@host:5432/spec_atlas_analysis
SPEC_DB_URL=postgresql+psycopg://user:password@host:5432/spec_atlas_spec

# --- LLM Provider (REQUIRED) ------
# Options: fake (local, free), claude (Anthropic), gemini (Google), groq (Groq), ollama (local)
LLM_PROVIDER=claude
# If using Claude:
GEMINI_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-3-5-sonnet-20241022  # or gemini-1.5-flash, etc.

# --- Embeddings Provider (REQUIRED) ------
# Options: fake (local, free), fastembed (local, free, default)
EMBED_PROVIDER=fastembed
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# --- API Security (REQUIRED) ------
# Comma-separated list of allowed CORS origins
# Do NOT use * in production (CORS security risk)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# --- Deployment (Optional) ------
# Set if running on Render.com, Fly.io, or other cloud platforms
PORT=8000
